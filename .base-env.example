# App
APP_NAME=Accelerator
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=daily,nightwatch
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database
DB_CONNECTION=sqlite
DB_SOCKET=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Session
SESSION_DRIVER=redis
SESSION_STORE=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_OCTANE_TABLE=sessions
SESSION_OCTANE_TABLE_ROWS=2048
SESSION_OCTANE_TABLE_BYTES=65535

# Runtime
SERVER_RUNTIME=swoole
INFRA_HOSTING=dedicated
OCTANE_SERVER=swoole
HORIZON_NAME=
HORIZON_PREFIX=
OCTANE_HOST=
OCTANE_PORT=
OCTANE_HTTPS=

# Drivers
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:3013
MEILISEARCH_KEY=

# Redis
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=
REVERB_SERVER_PORT=

# PDF
LARAVEL_PDF_DRIVER=gotenberg
GOTENBERG_URL=http://localhost:3011

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# WebPush
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Nightwatch
NIGHTWATCH_ENABLED=true
NIGHTWATCH_TOKEN=
NIGHTWATCH_LOG_LEVEL=error
NIGHTWATCH_CAPTURE_REQUEST_PAYLOAD=true
NIGHTWATCH_CAPTURE_EXCEPTION_SOURCE_CODE=true
NIGHTWATCH_IGNORE_REQUEST_HEADERS=true
NIGHTWATCH_IGNORE_QUERIES=true
NIGHTWATCH_IGNORE_OUTGOING_REQUESTS=true
NIGHTWATCH_IGNORE_CACHE_EVENTS=true
NIGHTWATCH_IGNORE_MAIL=true
NIGHTWATCH_IGNORE_NOTIFICATIONS=true
NIGHTWATCH_EXCEPTION_SAMPLE_RATE=1.0
NIGHTWATCH_COMMAND_SAMPLE_RATE=0.0
NIGHTWATCH_REQUEST_SAMPLE_RATE=0.0
NIGHTWATCH_SCHEDULED_TASK_SAMPLE_RATE=1.0

# Development
DEV_LOGIN=
DEV_PASSWORD=
